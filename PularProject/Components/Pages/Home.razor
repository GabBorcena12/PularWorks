<div class="modal thank-you-modal" id="thank-you-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="thank-you-title">
    <div class="thank-you-modal-panel">
        <button class="modal-close thank-you-modal-close" type="button" aria-label="Close inquiry success message">&times;</button>
        <span class="eyebrow">Inquiry Sent</span>
        <h2 id="thank-you-title">Thank you for your inquiry!</h2>
        <p>Your quotation request has been sent successfully. Our team will review your details and contact you shortly.</p>

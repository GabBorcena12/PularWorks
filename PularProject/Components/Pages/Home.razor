    <section class="cta-section inquiry-section">
        <div class="section-shell inquiry-panel reveal">
            <div class="inquiry-layout">
                <div class="inquiry-copy">
                    <p class="eyebrow">Quotation inquiry form</p>
                    <h2>Share Your Project Requirements</h2>
                    <p>
                        Send your transformer specifications and project details through the inquiry form below. We will review the requirements and help you with the right configuration for your application.
                    </p>
                </div>
                <div class="inquiry-card">
                    <form class="inquiry-form" action="https://api.staticforms.dev/submit" method="post" novalidate>
                        <input type="hidden" name="apiKey" value="__STATIC_FORMS_API_KEY__" />
                        <input type="hidden" name="subject" value="New PULAR Quotation Inquiry" />
                        <div class="inquiry-grid">
                            <label class="inquiry-field">
                                <span>Company Name</span>
                                <input type="text" name="company-name" autocomplete="organization" />
                            </label>
                            <label class="inquiry-field">
                                <span>Attention To</span>
                                <input type="text" name="attention-to" autocomplete="name" />
                            </label>
                            <label class="inquiry-field">
                                <span>Email Address</span>
                                <input type="email" name="email-address" autocomplete="email" />
                            </label>
                            <label class="inquiry-field">
                                <span>kVA Rating</span>
                                <input type="text" name="kva-rating" />
                            </label>
                            <label class="inquiry-field">
                                <span>Primary Voltage</span>
                                <input type="text" name="primary-voltage" />
                            </label>
                            <label class="inquiry-field">
                                <span>Secondary Voltage</span>
                                <input type="text" name="secondary-voltage" />
                            </label>
                            <label class="inquiry-field">
                                <span>Connection</span>
                                <select name="connection">
                                    <option value="">Select connection</option>
                                    <option>Auto Type</option>
                                    <option>Induction</option>
                                </select>
                            </label>
                            <label class="inquiry-field">
                                <span>Phase</span>
                                <select name="phase">
                                    <option value="">Select phase</option>
                                    <option>3 Phase</option>
                                    <option>Single Phase</option>
                                </select>
                            </label>
                            <label class="inquiry-field inquiry-field-full">
                                <span>Winding</span>
                                <select name="winding">
                                    <option value="">Select winding</option>
                                    <option>Aluminum</option>
                                    <option>Copper</option>
                                </select>
                            </label>
                        </div>
                        <input type="text" name="honeypot" class="inquiry-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
                        <button class="btn btn-primary inquiry-submit" type="submit" data-submit-label="Submit Inquiry">Submit Inquiry</button>
                        <p class="form-success" id="form-success" role="status" aria-live="polite"></p>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>


@page "/"

<PageTitle>PULAR | Reliable Quality Transformers and Electrical Equipment</PageTitle>

<header class="site-header" data-site-header>
    <a class="brand" href="#top" aria-label="PULAR home">
        <span class="brand-logo">
            <img src="images/pular-logo-full-transparent.png" alt="" aria-hidden="true" />
        </span>
        <span>PULAR</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
        <a href="#products" data-nav-link="products">Services</a>
        <a href="#projects" data-nav-link="projects">Projects</a>
        <a href="#about" data-nav-link="about">About</a>
        <a href="#contact" data-nav-link="contact">Contact</a>
    </nav>

    <a class="header-cta" href="#contact">Get a Quote</a>
</header>

<main id="top">
    <section class="hero section-band">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="section-shell hero-grid">
            <div class="hero-copy reveal">
                <p class="eyebrow">Reliable transformer and electrical equipment supply</p>
                <h1>Reliable Power Starts with Quality Transformers.</h1>
                <p class="hero-lede">
                    PULAR provides dependable transformer and electrical equipment solutions built for reliable performance, safe power distribution, long-term durability, and customer satisfaction.
                </p>
                <div class="action-row">
                    <a class="btn btn-primary" href="#contact">Get a Quote</a>
                    <a class="btn btn-secondary" href="#products">View Services</a>
                </div>
            </div>

            <div class="hero-visual reveal reveal-scale">
                <div class="hero-photo-frame">
                    <img src="images/hero/hero-transformer.jpg" alt="Open dry type transformer with copper windings" />
                </div>
            </div>
        </div>
        <a class="scroll-indicator" href="#products" aria-label="Scroll to products">
            <span>Scroll</span>
            <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                <path d="M12 5v14" />
                <path d="m6 13 6 6 6-6" />
            </svg>
        </a>
    </section>

    <section class="trust-strip section-shell" aria-label="Trust highlights">
        @foreach (var badge in TrustBadges)
        {
            <div class="trust-badge reveal">
                <span class="trust-icon trust-icon-@badge.Icon" aria-hidden="true">
                    @switch (badge.Icon)
                    {
                        case "shield":
                            <svg viewBox="0 0 24 24" role="img">
                                <path d="M12 3 5 6v5c0 4.6 2.9 8.8 7 10 4.1-1.2 7-5.4 7-10V6l-7-3Z" />
                                <path d="m8.8 12.2 2.1 2.1 4.4-5" />
                            </svg>
                            break;
                        case "gear":
                            <svg viewBox="0 0 24 24" role="img">
                                <path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" />
                                <path d="M3 12h3m12 0h3M12 3v3m0 12v3m-6.4-2.6 2.1-2.1m8.6-8.6 2.1-2.1m0 12.8-2.1-2.1M7.7 7.7 5.6 5.6" />
                            </svg>
                            break;
                        case "pin":
                            <svg viewBox="0 0 24 24" role="img">
                                <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" />
                                <path d="M12 10.5h.01" />
                            </svg>
                            break;
                        default:
                            <svg viewBox="0 0 24 24" role="img">
                                <path d="M4 7h16" />
                                <path d="M6 7v10h12V7" />
                                <path d="M9 17v-6h6v6" />
                            </svg>
                            break;
                    }
                </span>
                <span class="trust-label">@badge.Text</span>
            </div>
        }
    </section>

    <section id="products" class="section-shell section-pad expandable-section" data-expandable-section data-mobile-visible-count="3">
        <div class="section-heading reveal">
            <p class="eyebrow">Services / Products Offered</p>
            <h2>Electrical Equipment and Transformer Solutions Built for Long-Term Performance</h2>
        </div>

        <div class="product-grid">
            @foreach (var product in Products)
            {
                <article class="product-card reveal">
                    <div class="product-image">
                        <img src="@product.ImagePath" alt="@product.ImageAlt" loading="lazy" />
                    </div>
                    <div class="card-body">
                        <h3>@product.Name</h3>
                        <p>@product.Description</p>
                        <a href="#contact">Request Service</a>
                    </div>
                </article>
            }
        </div>
        <button class="section-toggle" type="button" data-expand-toggle aria-expanded="false">
            Show More
        </button>
    </section>

    <section class="feature section-band">
        <div class="section-shell feature-grid">
            <div class="feature-copy reveal reveal-left">
                <p class="eyebrow">Transformer supply</p>
                <h2>Dependable Transformer Solutions You Can Trust</h2>
                <p>
                    PULAR transformer solutions are built for quality workmanship, safe power distribution, reliable performance, and long-term durability.
                </p>
                <ul class="check-list">
                    <li>Built for reliability</li>
                    <li>Made for long-term performance</li>
                    <li>Quality transformers for safe and stable power</li>
                    <li>Supported with customer-focused service</li>
                </ul>
            </div>

            <div class="feature-visual reveal reveal-right">
                <div class="transformer-supply-photo">
                    <img src="images/sections/transformer-supply.png" alt="PULAR transformer supply equipment lineup" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section id="projects" class="projects section-band expandable-section" data-expandable-section data-mobile-visible-count="2">
        <div class="section-shell section-pad">
            <div class="section-heading reveal">
                <p class="eyebrow">Project proof</p>
                <h2>Real Equipment. Real Projects. Real Trust.</h2>
            </div>

            <div class="project-grid">
                @foreach (var project in Projects)
                {
                    <article class="project-card facebook-card reveal">
                        <div class="project-image project-proof-image">
                            <img src="@project.ImagePath" alt="@project.ImageAlt" loading="lazy" />
                        </div>
                        <div class="project-content">
                            <span class="facebook-label">@project.Meta</span>
                            <h3>@project.Title</h3>
                            <p>@project.Caption</p>
                            <a class="facebook-link" href="@project.Url" target="_blank" rel="noopener noreferrer">View Facebook Post</a>
                        </div>
                    </article>
                }
            </div>
            <button class="section-toggle" type="button" data-expand-toggle aria-expanded="false">
                Show More
            </button>
        </div>
    </section>

    <section id="about" class="section-shell about section-pad">
        <div class="about-copy reveal">
            <p class="eyebrow">About PULAR</p>
            <h2>Power You Can Trust.</h2>
            <div class="about-intro">
                <div class="about-logo-panel">
                    <img src="images/pular-logo-full-transparent.png" alt="PULAR Electrical Services and Supply logo" />
                </div>
                <p>
                    Established in 2007, PULAR has been providing electrical equipment and power solutions for construction and industrial companies throughout the Philippines.
                    We focus on dependable products, responsive service, and practical support to meet every project's electrical requirements.
                </p>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card stat-card-secure reveal">
                <span class="stat-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img">
                        <path d="M12 3 5 6v5c0 4.6 2.9 8.8 7 10 4.1-1.2 7-5.4 7-10V6l-7-3Z" />
                        <path d="m8.8 12.2 2.1 2.1 4.4-5" />
                    </svg>
                </span>
                <span class="stat-kicker">Trusted / Secure</span>
                <strong>Verified</strong>
                <span>Supplier commitment</span>
            </div>
            <div class="stat-card stat-card-counter reveal">
                <span class="stat-kicker">Customer Trust</span>
                <strong><span class="stat-number" data-count-to="50" data-count-suffix="+">0</span></strong>
                <span>Clients served</span>
            </div>
            <div class="stat-card stat-card-support reveal">
                <span class="stat-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img">
                        <path d="M4 13a8 8 0 0 1 16 0" />
                        <path d="M4 13v3a2 2 0 0 0 2 2h1v-7H6a2 2 0 0 0-2 2Z" />
                        <path d="M20 13v3a2 2 0 0 1-2 2h-1v-7h1a2 2 0 0 1 2 2Z" />
                        <path d="M16 18c0 1.1-.9 2-2 2h-2" />
                        <path d="M12 7v5l3 2" />
                    </svg>
                </span>
                <span class="stat-kicker">Always Ready</span>
                <strong>Mon-Sat</strong>
                <span>Construction & industrial support</span>
            </div>
            <div class="stat-card reveal">
                <span class="stat-kicker">Project Reach</span>
                <strong>Nationwide</strong>
                <span>Serving projects across the Philippines</span>
            </div>
        </div>
    </section>

